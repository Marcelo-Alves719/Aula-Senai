namespace atividadegit.Model
{
    class Gestaohsdf
    {
        private HistoricoDeFuncionario[] historico = new HistoricoDeFuncionario[1000];
        private int indexHistorico = 0;

        public void CadastrarHistoricoFuncionario(HistoricoDeFuncionario his)
        {
            this.historico[indexHistorico] = his;
            indexHistorico++;
        }

        public HistoricoDeFuncionario[] GetVetorHdf()
        {
            return historico;
        }
    }
}