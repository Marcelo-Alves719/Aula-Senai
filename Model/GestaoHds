namespace atividadegit.Model
{
    class GestaoHds
    {
        private HistoricoDeSalario[] hsalario = new HistoricoDeSalario[1000];
        private int idhistoricosalario = 0;

        public void CadastrarHistoricoSalarial(HistoricoDeSalario his)
        {
            this.hsalario[idhistoricosalario] = his;
            idhistoricosalario++;
        }

        public HistoricoDeSalario[] GetVetorHistoricoSalario()
        {
            return hsalario;
        }
    }
}